# AWS S3 Configuration (Required if not using the global ~/.secrets-manager/.env file)
AWS_ACCESS_KEY=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_DEFAULT_REGION=your_aws_region_here
AWS_S3_BUCKET_NAME=your_s3_bucket_name_here

# Fernet Salt Configuration
# (Optional: Only used as a fallback for decrypting legacy files)
FERNET_SALT=your_legacy_salt_here
